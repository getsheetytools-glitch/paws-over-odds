<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <div class="footer-brand">
        <div class="footer-logo">🐾 Paws Beyond Odds</div>
        <p class="footer-tagline">{{ site.description }}</p>
        <div class="footer-memory">
          <span class="memory-label">In loving memory</span>
          <span class="memory-names">Minou &middot; Yams &middot; Murphy &middot; Artie &middot; Bruce</span>
          <em>You taught us everything. We're still learning.</em>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Conditions</div>
        <ul>
          {% for condition in conditions %}
          <li><a href="/conditions/{{ condition.slug }}/">{{ condition.name }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">Resources</div>
        <ul>
          <li><a href="{{ '/conditions/ckd/' | url }}">New CKD Diagnosis</a></li>
          <li><a href="{{ '/advocate/' | url }}">Vet Advocacy Toolkit</a></li>
          <li><a href="{{ '/milton-sorbet/' | url }}">Milton & Sorbet Updates</a></li>
          <li><a href="{{ '/our-cats/' | url }}">Our Cats</a></li>
          <li><a href="{{ '/promotions/' | url }}">Deals & Discount Codes</a></li>
          <li><a href="{{ '/about/' | url }}">About This Site</a></li>
          <li><a href="{{ '/contact/' | url }}">Contact</a></li>
          <li><a href="{{ '/printables/vet-questions/' | url }}">Printable Vet Card</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-region-note">
      <div class="region-inner">
        🌎 {{ site.regionNote }}
      </div>
    </div>
    <div class="footer-bottom">
      <p>Built with love. No ads. No false promises. Just everything we know.</p>
      <div class="footer-symbol">🐾 <strong>&gt;</strong> odds</div>
    </div>
  </div>
</footer>
